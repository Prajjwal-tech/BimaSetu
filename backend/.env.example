# BimaSetu Backend Environment Variables
# Copy to .env and fill in your values

# Model paths (leave blank to use rule-based fallbacks)
YOLO_SEG_MODEL_PATH=./ml/model_weights/yolov8-seg.pt
CLASSIFIER_WEIGHTS_PATH=./ml/model_weights/resnet50_damage.pth

# SQLite database path
DB_PATH=./bimasetu.db

# Public base URL for serving static files
BASE_URL=http://localhost:8000
